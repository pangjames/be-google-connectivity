# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=hotel_user
DB_PASSWORD=your_db_password
DB_DATABASE=hotel_db

# AWS SQS Configuration
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SQS_SYNC_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/123456789012/google-sync-queue.fifo
AWS_SQS_PROPERTY_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/123456789012/property-sync-queue.fifo
USE_SQS_MOCK=false

# Google Hotel ARI API Configuration
GOOGLE_HOTEL_ARI_URL=https://www.google.com/travel/hotels/uploads/ari
GOOGLE_HOTEL_AUTH_TOKEN=your_google_oauth_bearer_token_here

# Application Configuration
ADMIN_API_TOKEN=your_super_secret_admin_token_here
PORT=3000

# Rolling Horizon Configuration
# Number of months to sync ahead (default 3, max 12)
ROLLING_HORIZON_MONTHS=3
